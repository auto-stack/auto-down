{
  "name": "@autodown/editor",
  "version": "0.1.0",
  "description": "AutoDown editor — Tiptap-based WYSIWYG editor for AutoDown documents",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "lucide-vue-next": "^0.460.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@autodown/core": "workspace:*",
    "@tiptap/core": "^3.27.0",
    "@tiptap/extension-code-block": "^3.27.0",
    "@tiptap/extension-code-block-lowlight": "^3.27.0",
    "@tiptap/extension-collaboration": "^3.27.0",
    "@tiptap/extension-collaboration-cursor": "^2.26.2",
    "@tiptap/extension-drag-handle": "^3.27.0",
    "@tiptap/extension-image": "^3.27.0",
    "@tiptap/extension-link": "^3.27.0",
    "@tiptap/extension-node-range": "^3.27.0",
    "@tiptap/extension-placeholder": "^3.27.0",
    "@tiptap/extension-table": "^3.27.0",
    "@tiptap/extension-table-cell": "^3.27.0",
    "@tiptap/extension-table-header": "^3.27.0",
