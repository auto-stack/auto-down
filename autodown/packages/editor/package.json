    "@tiptap/extension-task-item": "^3.27.0",
    "@tiptap/extension-task-list": "^3.27.0",
    "@tiptap/markdown": "^3.27.0",
    "@tiptap/pm": "^3.27.0",
    "@tiptap/starter-kit": "^3.27.0",
    "@tiptap/suggestion": "^3.27.0",
    "@tiptap/vue-3": "^3.27.0",
    "@tiptap/y-tiptap": "^3.0.5",
    "lowlight": "^3.3.0",
    "tiptap-markdown": "^0.8.10",
    "y-prosemirror": "^1.3.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
