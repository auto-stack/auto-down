{
  "name": "@autodown/vue",
  "version": "0.1.0",
  "description": "AutoDown Vue renderer — streaming and static document rendering for AutoDown",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@autodown/core": "workspace:*",
    "hast-util-to-html": "9.0.5",
    "lowlight": "^3.3.0",
    "markstream-vue": "^0.0.14-beta.8",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.0"
  }
}
